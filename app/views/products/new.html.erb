<% content_for :title, "New product" %>

<div class="min-h-screen flex items-center justify-center px-4 py-10 mx-auto">
  <div class="w-full max-w-2xl bg-white shadow-sm border border-gray-100 rounded-2xl p-8">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">New product</h1>
      <p class="text-gray-500 mt-1">Create a new product for your catalog</p>
    </div>

    <%= render "form", product: @product %>

    <div class="mt-6 flex justify-between items-center">
      <%= link_to "Back to products", products_path,
        class: "text-sm text-gray-600 hover:text-gray-900 underline underline-offset-4" %>
    </div>

  </div>
</div>
