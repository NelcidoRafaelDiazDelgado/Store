<div id="<%= dom_id product %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= product.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Sku:</strong>
    <%= product.sku %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= product.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Price:</strong>
    <%= product.price %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Category:</strong>
    <%= product.category %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Amount:</strong>
    <%= product.amount %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Min:</strong>
    <%= product.min %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Status:</strong>
    <%= product.status? ? "Yes" : "No" %>
  </div>
</div>
