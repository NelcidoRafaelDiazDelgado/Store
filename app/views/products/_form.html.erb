<%= form_with(model: product, class: "space-y-5") do |form| %>

  <% if product.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl">
      <h2 class="font-medium">
        <%= pluralize(product.errors.count, "error") %> prevented saving:
      </h2>

      <ul class="list-disc ml-5 mt-2 text-sm">
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Name -->
  <div>
    <%= form.label :name, class: "text-sm font-medium text-gray-700" %>
    <%= form.text_field :name,
      class: "mt-1 w-full rounded-xl border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:name].any? ? 'border-red-400' : 'border-gray-200'}"
    %>
  </div>

  <!-- Description -->
  <div>
    <%= form.label :description, class: "text-sm font-medium text-gray-700" %>
    <%= form.textarea :description, rows: 4,
      class: "mt-1 w-full rounded-xl border px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:description].any? ? 'border-red-400' : 'border-gray-200'}"
    %>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

    <div>
      <%= form.label :price, class: "text-sm font-medium text-gray-700" %>
      <%= form.text_field :price,
        class: "mt-1 w-full rounded-xl border px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none #{product.errors[:price].any? ? 'border-red-400' : 'border-gray-200'}"
      %>
    </div>

    <div>
      <%= form.label :sku, class: "text-sm font-medium text-gray-700" %>
      <%= form.text_field :sku,
        class: "mt-1 w-full rounded-xl border px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none #{product.errors[:sku].any? ? 'border-red-400' : 'border-gray-200'}"
      %>
    </div>

    <div>
      <%= form.label :amount, class: "text-sm font-medium text-gray-700" %>
      <%= form.number_field :amount,
        class: "mt-1 w-full rounded-xl border px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none #{product.errors[:amount].any? ? 'border-red-400' : 'border-gray-200'}"
      %>
    </div>

    <div>
      <%= form.label :min, class: "text-sm font-medium text-gray-700" %>
      <%= form.number_field :min,
        class: "mt-1 w-full rounded-xl border px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none #{product.errors[:min].any? ? 'border-red-400' : 'border-gray-200'}"
      %>
    </div>

  </div>

  <!-- Status -->
  <div>
    <%= form.label :status, class: "text-sm font-medium text-gray-700" %>
    <%= form.text_field :status,
      class: "mt-1 w-full rounded-xl border px-3 py-2 focus:ring-2 focus:ring-blue-500 outline-none #{product.errors[:status].any? ? 'border-red-400' : 'border-gray-200'}"
    %>
  </div>

  <!-- Submit -->
  <div class="pt-2">
    <%= form.submit "Create product",
      class: "w-full rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-medium py-2.5 transition"
    %>
  </div>

<% end %>
