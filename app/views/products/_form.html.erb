<%= form_with(model: product, class: "max-w-3xl mx-auto bg-white ring-gray-200 rounded-xl p-6 space-y-6") do |form| %>

  <% if product.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">
      <h2 class="font-semibold mb-2">
        <%= pluralize(product.errors.count, "error") %> evitaron guardar el producto:
      </h2>

      <ul class="list-disc pl-5 space-y-1 text-sm">
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

    <div class="space-y-2">
      <%= form.label :name, class: "text-sm font-medium text-gray-700" %>
      <%= form.text_field :name,
        class: "w-full rounded-lg border px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:name].any? ? 'border-red-400' : 'border-gray-300'}"
      %>
    </div>

    <div class="space-y-2 md:col-span-2">
      <%= form.label :description, class: "text-sm font-medium text-gray-700" %>
      <%= form.textarea :description, rows: 4,
        class: "w-full rounded-lg border px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:description].any? ? 'border-red-400' : 'border-gray-300'}"
      %>
    </div>

    <div class="space-y-2">
      <%= form.label :price, class: "text-sm font-medium text-gray-700" %>
      <%= form.text_field :price,
        class: "w-full rounded-lg border px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:price].any? ? 'border-red-400' : 'border-gray-300'}"
      %>
    </div>

    <div class="space-y-2">
      <%= form.label :sku, class: "text-sm font-medium text-gray-700" %>
      <%= form.text_field :sku,
        class: "w-full rounded-lg border px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:sku].any? ? 'border-red-400' : 'border-gray-300'}"
      %>
    </div>

    <div class="space-y-2">
      <%= form.label :minimum, class: "text-sm font-medium text-gray-700" %>
      <%= form.number_field :minimum,
        class: "w-full rounded-lg border px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:minimum].any? ? 'border-red-400' : 'border-gray-300'}"
      %>
    </div>

    <div class="space-y-2">
      <%= form.label :amount, class: "text-sm font-medium text-gray-700" %>
      <%= form.number_field :amount,
        class: "w-full rounded-lg border px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none #{product.errors[:amount].any? ? 'border-red-400' : 'border-gray-300'}"
      %>
    </div>

    <div class="flex items-center gap-3 md:col-span-2">
      <%= form.check_box :status,
        class: "h-5 w-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
      %>
      <%= form.label :status, class: "text-sm font-medium text-gray-700" %>
    </div>

  </div>

  <div class="flex justify-end pt-4 border-t border-gray-100">
    <%= form.submit "Guardar producto",
      class: "px-5 py-2.5 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-500 transition"
    %>
  </div>

<% end %>